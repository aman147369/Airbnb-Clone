<% layout('boilerplate') -%>

<body>
    <h1 class="col col-6 offset-3">Login</h1>
    <div class="row mt-3">
        <div class="col col-6 offset-3">
            <form action="/login" method="post" novalidate class="needs-validation">
                <div class="mb-2">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" name="username" placeholder="username" id="username" class="form-control" required>
                </div>
            
                <div class="mb-2">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" name="password" placeholder="password" id="password" class="form-control" required>
                </div>
                <button class="btn btn-success mb-2">Login</button>
            </form>
        </div>
    </div>
    
</body>
